NEXTJS_ENV=development

# Contentful CMS — replace with your real values from Contentful → Settings → API keys
CONTENTFUL_SPACE_ID=your_space_id_here
CONTENTFUL_ACCESS_TOKEN=your_content_delivery_api_token_here
CONTENTFUL_ENVIRONMENT=master

# Random secret shared with the Contentful webhook (Settings → Webhooks → custom header x-revalidate-secret)
CONTENTFUL_REVALIDATE_SECRET=your_random_secret_here
